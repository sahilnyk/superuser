---
const technologies = [
  { name: "Python", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" },
  { name: "TypeScript", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" },
  { name: "React", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg" },
  { name: "PostgreSQL", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg" },
  { name: "FastAPI", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/fastapi/fastapi-original.svg" },
  { name: "Django", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/django/django-plain.svg" },
  { name: "AWS", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/amazonwebservices/amazonwebservices-original-wordmark.svg" },
  { name: "Docker", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" },
  { name: "Terraform", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/terraform/terraform-original.svg" },
  { name: "Git", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg" },
  { name: "Linux", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linux/linux-original.svg" },
  { name: "Node.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-plain.svg" },
  { name: "LangChain", icon: "https://api.iconify.design/simple-icons:langchain.svg?color=%23ffffff" },
  { name: "Shadcn", icon: "https://ui.shadcn.com/apple-touch-icon.png" },
];
---

<section class="tech-stack">
  <h2>Technologies I work on</h2>
  <div class="tech-carousel">
    <div class="tech-track">
      {technologies.concat(technologies).map((tech, index) => (
        <div class="tech-item" key={index}>
          <img src={tech.icon} alt={tech.name} loading="lazy" />
          <span>{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-stack {
    margin: 3rem 0;
    padding: 2rem 0;
  }

  h2 {
    font-size: 20px !important;
    font-weight: 400;
    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .tech-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .tech-track {
    display: flex;
    gap: 3rem;
    animation: scroll 60s linear infinite;
    width: max-content;
  }

  .tech-track:hover {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: no-preference) {
    .tech-track {
      animation: scroll 60s linear infinite;
    }
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    min-width: 80px;
    opacity: 0.6;
    transition: opacity var(--transition-base);
  }

  .tech-item:hover {
    opacity: 1;
  }

  .tech-item img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: grayscale(1) brightness(2);
    opacity: 0.7;
  }

  .tech-item span {
    font-size: var(--text-xs);
    white-space: nowrap;
    opacity: 0.7;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-100% / 2));
    }
  }

  @media (max-width: 768px) {
    .tech-stack {
      margin: 2rem 0;
      padding: 1.5rem 0;
    }

    .tech-stack h2 {
      font-size: 16px !important;
      margin-bottom: 1.5rem;
    }

    .tech-track {
      gap: 2rem;
      animation: scroll 40s linear infinite;
    }

    .tech-item {
      min-width: 60px;
    }

    .tech-item img {
      width: 32px;
      height: 32px;
    }
  }
</style>
