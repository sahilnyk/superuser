---
import Section from "../components/ui/Section.astro";
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../components/layout/BaseLayout.astro";
import ContentList from "../components/shared/ContentList.astro";
import Container from "../components/ui/Container.astro";
import TechStack from "../components/shared/TechStack.astro";

const siteConfig = await getEntry("site", "home");
if (!siteConfig) {
  throw new Error("Site configuration not found");
}

const site = siteConfig.data;

const formatDate = (date: Date | undefined) => {
  if (!date) return "";
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
};

const posts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const latestPosts = posts
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  )
  .slice(0, 3);

const experiences = await getCollection("experience");
const sortedExperiences = experiences.sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) => {
    // Current positions first
    if (a.data.current && !b.data.current) return -1;
    if (!a.data.current && b.data.current) return 1;
    // Then sort by start date (most recent first)
    return b.data.startDate.getTime() - a.data.startDate.getTime();
  }
);

const projects = await getCollection("projects");
const featuredProjects = projects.filter((project: CollectionEntry<"projects">) => project.data.featured).slice(0, 3);
---

<BaseLayout title={`${site.name} - Portfolio`} description={site.introduction}>
  <Container>
    <section class="hero">
      <h1>{site.name}</h1>
      <p class="subtitle">{site.title}</p>
      <p class="introduction">
        I'm constantly learning and evolving. I love diving into new ideas and finding creative ways to solve problems. When I'm not coding, you'll find me strategizing on <a href="https://www.chess.com/member/sah669" target="_blank" rel="noopener noreferrer" class="mention-link">@chess.com</a> or grinding problems on <a href="https://www.hackerrank.com/profile/contactsahilpna1" target="_blank" rel="noopener noreferrer" class="mention-link">@hackerrank</a>.
      </p>
      {
        site.socialLinks && (
          <div class="social-links">
            {site.socialLinks.map(({ platform, url }) => (
              <a href={url} target="_blank" rel="noopener noreferrer" class="social-link">
                {platform === "GitHub" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
                {platform === "Twitter" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {platform && <span>{platform}</span>}
              </a>
            ))}
          </div>
        )
      }
    </section>

    <section class="video-intro">
      <div class="video-container">
        <iframe
          src="https://www.youtube.com/embed/jNQXAC9IVRw?si=0JQa2xjufCpN2v8K"
          title="Video Introduction"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <p class="video-note"><em>will change this with real intro coz haven't made one yet</em></p>
    </section>

    <TechStack />

    <Section>
      <div class="section-header">
        <h2>{site.sections.blog.title}</h2>
        <a href="/blog">{site.sections.blog.viewAllText}</a>
      </div>
      <ContentList>
        {
          latestPosts.map((post) => (
            <article>
              <div class="title-row">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
                {post.data.publishedAt && (
                  <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
                )}
              </div>
              <p class="muted-text">{post.data.description}</p>
            </article>
          ))
        }
      </ContentList>
    </Section>

    <Section>
      <div class="section-header">
        <h2>{site.sections.projects.title}</h2>
        <a href="/projects">{site.sections.projects.viewAllText}</a>
      </div>
      <ContentList>
        {
          featuredProjects.map((project) => (
            <article>
              <div class="title-row">
                <a href={project.data.url} target="_blank" rel="noopener noreferrer">
                  {project.data.title}
                </a>
              </div>
              <p class="muted-text">{project.data.description}</p>
              {project.data.techs && (
                <div class="tags">
                  {project.data.techs.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </ContentList>
    </Section>

    <Section>
      <div class="section-header">
        <h2>{site.sections.experience.title}</h2>
        <a href="/experience">{site.sections.experience.viewAllText}</a>
      </div>
      <div class="content-list">
        {
          sortedExperiences.slice(0, 3).map((exp) => {
            const [role, company] = exp.data.title.split(" at ");
            return (
              <article>
                <div class="exp-header">
                  <div class="exp-role">
                    <img src={exp.data.logo} alt="" class="company-logo" />
                    <span class="role-title">{role}</span>
                  </div>
                  <time>
                    {formatDate(exp.data.startDate)} - {exp.data.current ? "Present" : formatDate(exp.data.endDate)}
                  </time>
                </div>
                {company && <p class="company-name">@{company}</p>}
                <p class="muted-text">{exp.data.description}</p>
              </article>
            );
          })
        }
      </div>
    </Section>
  </Container>
</BaseLayout>

<style>
  main {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .hero {
    padding: 4rem 0;
  }

  .introduction {
    margin: 1.5rem 0;
    opacity: 0.9;
  }

  .mention-link {
    color: #60a5fa;
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .mention-link:hover {
    opacity: 0.8;
  }

  .section {
    margin: 4rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
  }

  .title-row a {
    flex: 0 1 auto;
    min-width: 0;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .exp-role {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .role-title {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .company-logo {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
    flex-shrink: 0;
  }

  .company-name {
    font-size: var(--text-xs);
    opacity: 0.6;
    margin: 0 0 0.75rem 2.25rem;
  }

  time {
    font-size: var(--text-xs);
    opacity: 0.5;
    white-space: nowrap;
    margin-left: auto;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .tags span {
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    opacity: 0.7;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity var(--transition-base);
  }

  .social-link:hover {
    opacity: 1;
  }

  .social-link svg {
    flex-shrink: 0;
  }

  .video-intro {
    margin: 4rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .video-container {
    position: relative;
    width: 100%;
    max-width: 800px;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.03) 0%,
      rgba(255, 255, 255, 0.01) 100%
    );
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition: all 0.3s ease;
  }

  .video-container::before {
    content: '';
    position: absolute;
    inset: -2px;
    background: linear-gradient(
      135deg,
      rgba(123, 104, 238, 0.2),
      rgba(139, 92, 246, 0.2),
      rgba(123, 104, 238, 0.2)
    );
    border-radius: 13px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .video-container:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 0 40px rgba(139, 92, 246, 0.15);
  }

  .video-container:hover::before {
    opacity: 1;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 12px;
  }

  .video-note {
    margin-top: 1.5rem;
    font-size: var(--text-xs);
    opacity: 0.5;
    text-align: center;
  }

  @media (max-width: 640px) {
    main {
      padding: 1rem 0;
    }

    .hero {
      padding: 2rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .section {
      margin: 3rem 0;
      padding: 0 1rem;
    }

    .content-list {
      padding: 0 0.5rem;
    }

    .section-header {
      margin-bottom: 1.5rem;
      flex-direction: row;
      align-items: baseline;
      gap: 0.5rem;
    }

    .section-header h2 {
      font-size: 1rem;
    }

    .section-header a {
      font-size: 0.75rem;
    }

    article {
      padding: 1.25rem 0.5rem;
    }

    .title-row {
      gap: 1rem;
    }

    .exp-header {
      flex-direction: row;
      align-items: flex-start;
      gap: 0.5rem;
      margin-bottom: 0.1rem;
    }

    .exp-role {
      flex: 1;
    }

    .role-title {
      font-size: 0.8rem;
    }

    .company-name {
      margin-left: 2.25rem;
      margin-top: 0;
    }

    time {
      font-size: 0.65rem;
      flex-shrink: 0;
    }

    .muted-text {
      font-size: 0.875rem;
      line-height: 1.6;
      margin-top: 0.75rem;
    }

    .tags {
      flex-wrap: wrap;
    }

    .social-links {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .video-intro {
      margin: 3rem 0;
    }

    .video-container {
      max-width: 100%;
      border-radius: 8px;
    }

    .video-container:hover {
      transform: translateY(-2px);
    }
  }
</style>
